# Python — backend 전용 .gitignore (Hybrid 패턴)
# root .gitignore 는 cross-cutting (env, OS, editor) 만 담당.
# 이 파일은 backend/ 의 Python 툴체인 산출물 전담.

# ─── Python 캐시 / 컴파일 산출물 ─────────────────────
__pycache__/
*.py[cod]
*$py.class
.Python

# ─── 가상환경 ───────────────────────────────────────
.venv/
venv/
env/

# ─── 테스트 / 린터 / 타입 체커 캐시 ──────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ─── 빌드 / 배포 산출물 ─────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ─── 로컬 측정 / 평가 산출물 ────────────────────────
# 운영 영구 보관은 ~/Downloads. 로컬에서 임시 생성되는 파일들.
# 참고: tmp_match/ 는 실행 cwd (보통 repo root) 에 생성되어 root .gitignore 에서 처리.
progress.json
eval_results.json

# ─── Jupyter / 데이터 분석 임시 ─────────────────────
.ipynb_checkpoints/
