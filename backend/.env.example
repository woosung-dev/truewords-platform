# === 환경 구분 ===
ENVIRONMENT=development  # development | staging | production

# === AI ===
GEMINI_API_KEY=your_gemini_api_key_here

# === Qdrant ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
COLLECTION_NAME=malssum_poc_v5

# === PostgreSQL ===
DATABASE_URL=postgresql+asyncpg://truewords:truewords@localhost:5432/truewords

# === Admin JWT ===
ADMIN_JWT_SECRET=change-me-in-production
ADMIN_JWT_EXPIRE_MINUTES=1440

# === Frontend CORS ===
ADMIN_FRONTEND_URL=http://localhost:3000

# === Cookie 보안 (프로덕션에서 true) ===
COOKIE_SECURE=false

# === 임베딩 파이프라인 ===
# GEMINI_TIER 하나로 무료/유료 전환. 개별 override도 가능.
#
# ┌───────────────────────────┬──────────────┬──────────────────┐
# │ 항목                      │ free         │ paid             │
# ├───────────────────────────┼──────────────┼──────────────────┤
# │ TPM 한도                  │ 30K          │ 1,000,000        │
# │ RPM 한도                  │ 100          │ 3,000            │
# │ RPD 한도                  │ 1,000        │ 무제한            │
# │ → max_chars_per_batch     │ 31,000자     │ 900,000자        │
# │ → batch_sleep             │ 60초         │ 3초              │
# │ → rpd_limit               │ 950          │ 100,000          │
# └───────────────────────────┴──────────────┴──────────────────┘
#
GEMINI_TIER=free   # free | paid
#
# 개별 override (선택사항 — 프리셋 대신 직접 지정):
# EMBED_MAX_CHARS_PER_BATCH=31000
# EMBED_BATCH_SLEEP=60
# EMBED_RPD_LIMIT=950

# === Semantic Cache ===
CACHE_COLLECTION_NAME=semantic_cache
CACHE_THRESHOLD=0.93
CACHE_TTL_DAYS=7
