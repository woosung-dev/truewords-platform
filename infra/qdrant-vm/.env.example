# =============================================================================
# Qdrant 셀프 호스팅 VM — 환경 변수 템플릿
# =============================================================================
# 사용:
#   cp .env.example .env
#   # 아래 두 값을 채운 뒤
#   chmod 600 .env
#
# 주의:
#   - 이 파일(.env)은 절대 git에 커밋하지 않는다 (.gitignore 확인 필수).
#   - VM 부트스트랩(setup-vm.sh) 시 자동으로 chmod 600 적용됨.
#   - 토큰/키 회전 시: 두 곳 모두 갱신 (1) 본 .env, (2) GitHub Secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# QDRANT_API_KEY — Qdrant 서비스 자체 인증 키 (32 bytes 권장)
# -----------------------------------------------------------------------------
# 생성:
#   openssl rand -base64 32
#
# 사용처:
#   - VM 컨테이너: docker-compose가 QDRANT__SERVICE__API_KEY로 주입
#   - Cloud Run (FastAPI): GitHub Secrets QDRANT_API_KEY 와 동일 값이어야 함
#   - 마이그레이션 스크립트: QDRANT_VM_API_KEY 로 같은 값 사용
#
# 회전 절차:
#   1) 새 키 생성
#   2) 본 .env 갱신 → docker compose up -d 로 컨테이너 재기동
#   3) GitHub Secrets QDRANT_API_KEY 갱신 → Cloud Run 재배포
QDRANT_API_KEY=replace-me


# -----------------------------------------------------------------------------
# CLOUDFLARE_TUNNEL_TOKEN — Cloudflare Tunnel(qdrant-truewords) 인증 토큰
# -----------------------------------------------------------------------------
# 발급:
#   1) Cloudflare 대시보드 → Zero Trust → Networks → Connectors
#   2) `qdrant-truewords` 터널 클릭 → "Install connector" 단계
#   3) 명령어 박스의 `cloudflared tunnel run --token <TOKEN>` 에서 <TOKEN> 부분 복사
#      (토큰은 보통 `eyJhIjoi...` 로 시작하는 200자+의 base64 JWT)
#
# 사용처:
#   - VM 컨테이너: docker-compose가 cloudflared 데몬에 주입
#   - GitHub Secrets CLOUDFLARE_TUNNEL_TOKEN (선택, CI에서 사용 시)
#
# 회전 절차:
#   1) Cloudflare 대시보드에서 새 토큰 발급
#   2) 본 .env 갱신 → docker compose up -d cloudflared
#   3) (필요 시) GitHub Secrets 갱신
CLOUDFLARE_TUNNEL_TOKEN=replace-me
